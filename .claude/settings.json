{
  "enabledPlugins": {
    "prisma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/read_hook.js"
          }
        ]
      }
    ]
  }
}
